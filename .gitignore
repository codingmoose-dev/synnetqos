# Python cache
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Virtual environments
.venv/
venv/
env/

# Build/package artifacts
build/
dist/
*.egg-info/
*.egg-info

# Jupyter
.ipynb_checkpoints/

# OS/editor files
.DS_Store
.vscode/
.idea/

# Test/cache outputs
.coverage
htmlcov/

# Logs
*.log

# Local config
config/paths.yaml
config/local*.yaml

# Raw/intermediate/external datasets should stay local
data/raw/
data/interim/
data/external/

# Temporary/local result folders only
results/tmp/
results/debug/
results/local/

# Temporary/local figure folders only
figures/tmp/
figures/debug/
figures/working/

# Keep archive README only; do not push exploratory archived outputs
archive/*
!archive/README.md